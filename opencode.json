{
    "$schema": "https://opencode.ai/config.json",
    "lsp": true,
    "mcp": {
        "postgres": {
            "type": "local",
            "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "postgresql://wms:wms_secret@localhost:5432/wms"],
            "enabled": true
        },
        "github": {
            "type": "local",
            "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
            "environment": {
                "GITHUB_TOKEN": "${GITHUB_TOKEN}"
            },
            "enabled": true
        }
    }
}